DATABASE_URL="postgresql://USER:PASSWORD@EP-ID-pooler.REGION.aws.neon.tech/DB_NAME?sslmode=require"
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@EP-ID.REGION.aws.neon.tech/DB_NAME?sslmode=require"
NEON_VECTOR_URL="postgresql://USER:PASSWORD@EP-ID.REGION.aws.neon.tech/DB_NAME?sslmode=require"

JWT_SECRET="replace-with-a-long-random-secret"
ENCRYPTION_KEY="replace-with-exactly-32-utf8-chars-or-64-hex-chars"

PORT=5000
NODE_ENV=development

BACKEND_BASE_URL="http://localhost:5000"
FRONTEND_BASE_URL="http://localhost:5173"
EMAIL_WORKER_SECRET="replace-with-a-long-random-worker-secret"
EMAIL_POLLING_ENABLED=false
EMAIL_POLLING_INTERVAL_SECONDS=60
EMAIL_POLLING_MAX_RESULTS=10

# Optional fallback credentials for IMAP/SMTP. Production should prefer per-hotel EmailIntegration records.
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
HOTEL_EMAIL_FROM=

GOOGLE_PUBSUB_TOPIC="projects/YOUR_PROJECT_ID/topics/hotelogx-gmail-events"
GOOGLE_PUBSUB_AUDIENCE="https://your-cloud-run-url/api/webhooks/email/google/pubsub"
GOOGLE_PUBSUB_PUSH_SERVICE_ACCOUNT="pubsub-gmail-push@YOUR_PROJECT_ID.iam.gserviceaccount.com"

GOOGLE_OAUTH_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_OAUTH_CLIENT_SECRET="your-google-oauth-client-secret"
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:5000/api/email-integrations/google/callback"

MICROSOFT_OAUTH_CLIENT_ID="your-microsoft-entra-app-client-id"
MICROSOFT_OAUTH_CLIENT_SECRET="your-microsoft-entra-app-client-secret"
MICROSOFT_OAUTH_TENANT_ID="common"
MICROSOFT_OAUTH_REDIRECT_URI="http://localhost:5000/api/email-integrations/microsoft/callback"
